{
  "htmlWhitespaceSensitivity": "ignore",
  "printWidth": 120,
  "jsxBracketSameLine": false,
  "arrowParens": "avoid",
  "tabWidth": 2,
  "useTabs": true,
  "singleQuote": true,
  "quoteProps": "as-needed",
  "jsxSingleQuote": true,
  "trailingComma": "es5",
  "bracketSpacing": true,
  "semi": false
}